{
  "name": "intellihire",
  "private": true,
  "version": "1.0.0",
  "description": "Single entry point for the IntelliHire recruitment platform.",
  "scripts": {
    "dev": "npm --prefix recruitexam_v2_updated/app run dev:full",
    "server": "npm --prefix recruitexam_v2_updated/app run server",
