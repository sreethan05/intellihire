    "client": "npm --prefix recruitexam_v2_updated/app run dev",
    "build": "npm --prefix recruitexam_v2_updated/app run build",
    "check": "npm --prefix recruitexam_v2_updated/app run check",
    "lint": "npm --prefix recruitexam_v2_updated/app run lint",
    "preview": "npm --prefix recruitexam_v2_updated/app run preview",
    "start": "npm --prefix recruitexam_v2_updated/app run start"
  }
}
